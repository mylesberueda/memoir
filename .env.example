# ==============================================================================
# Postgres
# ==============================================================================
DB_USER="postgres"
DB_PASS="postgres"
DB_HOST="localhost"
DB_PORT="54321"
DB_NAME="memoir"

# ==============================================================================
# Redis
# ==============================================================================
REDIS_URL="redis://localhost:63791"
RD_HOST="localhost"
RD_PORT="63791"

# ==============================================================================
# Qdrant
# ==============================================================================
QDRANT_REST_PORT="6333"
QDRANT_GRPC_PORT="6334"

# ==============================================================================
# Ollama (optional - only with `--profile ai`)
# ==============================================================================
# GPU support for Ollama (set to 1 or 'all' to enable, 0 to disable)
OLLAMA_GPU_COUNT=1
# Local ollama storage, typically ~/.ollama, to share with your local instance.
OLLAMA_STORAGE=/home/myles/.ollama

# ==============================================================================
# NLI classifier (memoir-core, only with the `cuda` cargo feature)
# ==============================================================================
# Execution provider for the zero-shot NLI categorizer: auto | cuda | cpu.
# Ignored unless memoir-core is built with `--features cuda`; CPU-only builds
# always run on CPU. Defaults to `auto` (try CUDA, fall back to CPU).
# NLI_EXECUTION_PROVIDER=auto

# vim: set filetype=sh:
