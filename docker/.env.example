# Memoir full-stack deployment — copy to `.env` and edit.
#
# Vars are prefixed by container: MEMOIR_SERVICE_* and MEMOIR_UI_*. The compose
# file maps each to the bare name the app inside the container reads, so the two
# services never collide on a shared name here.
#
# Internal URLs use compose service names (postgres, qdrant, memoir-service, …)
# on CONTAINER ports — not localhost, not the host ports below. Change the
# *_HOST_PORT vars to remap what's exposed on your host.

# ==============================================================================
# memoir-service — required
# ==============================================================================
MEMOIR_SERVICE_JWT_SECRET=CHANGE_ME_base64_min_32_bytes_openssl_rand_base64_32

# ==============================================================================
# memoir-service — Postgres (the bundled database)
# ==============================================================================
MEMOIR_SERVICE_DB_USER=postgres
MEMOIR_SERVICE_DB_PASS=postgres
MEMOIR_SERVICE_DB_NAME=memoir_service
# Host port Postgres is published on (container port is always 5432).
MEMOIR_SERVICE_DB_PORT=54321

# ==============================================================================
# memoir-service — Qdrant (the bundled vector index)
# ==============================================================================
# Host ports (container ports are always 6333 REST / 6334 gRPC).
MEMOIR_SERVICE_QDRANT_REST_PORT=6333
MEMOIR_SERVICE_QDRANT_GRPC_PORT=6334

# ==============================================================================
# memoir-service — server
# ==============================================================================
MEMOIR_SERVICE_HOST=0.0.0.0
MEMOIR_SERVICE_PORT=5153
MEMOIR_SERVICE_HTTP_PORT=5154
# Postgres schemas isolating memoir's tables in a shared database.
MEMOIR_SERVICE_SCHEMA=memoir_service
MEMOIR_SERVICE_CORE_SCHEMA=memoir

# ==============================================================================
# memoir-service — extraction LLM (optional; unset = embed-only, no facts)
# ==============================================================================
MEMOIR_SERVICE_EXTRACTION_PROVIDER=
MEMOIR_SERVICE_EXTRACTION_URL=
MEMOIR_SERVICE_EXTRACTION_MODEL=
MEMOIR_SERVICE_EXTRACTION_API_KEY=

# ==============================================================================
# memoir-service — knowledge graph (optional; needs --profile knowledge-graph)
# ==============================================================================
# Unset = graph off. Set = connection validated at startup. The graph stays
# empty until a relational provider below is also set.
MEMOIR_SERVICE_FALKOR_URL=
MEMOIR_SERVICE_GRAPH_NAME=memoir
# Host port FalkorDB is published on (container port is always 6379).
MEMOIR_SERVICE_FALKOR_PORT=63792
MEMOIR_SERVICE_RELATIONAL_PROVIDER=
MEMOIR_SERVICE_RELATIONAL_URL=
MEMOIR_SERVICE_RELATIONAL_MODEL=
MEMOIR_SERVICE_RELATIONAL_API_KEY=

# ==============================================================================
# memoir-service — dev-mode admin (local only; leaks to docker inspect/logs)
# ==============================================================================
# DEV_MODE=true creates an admin from the vars below on first start, skipping
# the one-time bootstrap token. Leave false for any real deployment.
MEMOIR_SERVICE_DEV_MODE=false
MEMOIR_SERVICE_DEV_ADMIN_USERNAME=admin@example.com
MEMOIR_SERVICE_DEV_ADMIN_PASSWORD=change-me

# ==============================================================================
# memoir-ui — admin console
# ==============================================================================
MEMOIR_UI_SESSION_SECRET=CHANGE_ME_min_32_chars_openssl_rand_base64_32
MEMOIR_UI_PORT=3000
# Reaches the service over the compose network by service name + container port.
MEMOIR_UI_SERVICE_URL=http://memoir-service:5153
MEMOIR_UI_HTTP_URL=http://memoir-service:5154
MEMOIR_UI_REDIS_URL=redis://redis:6379
MEMOIR_UI_LOG_LEVEL=info
# Host port Redis is published on (container port is always 6379).
MEMOIR_UI_REDIS_PORT=63791

# vim: ft=sh
