# MEMOIR_EXTRACTION_PROVIDER=ollama
# MEMOIR_EXTRACTION_URL=http://localhost:11434
# MEMOIR_EXTRACTION_MODEL=llama3.2:1b
# MEMOIR_EXTRACTION_API_KEY=

# Dev-mode bootstrap: creates this admin on first start (dev only — env vars
# leak to `docker inspect`/logs). Username must be email-shaped for memoir-ui login.
# MEMOIR_DEV_MODE=true
# MEMOIR_DEV_ADMIN_USERNAME=admin@polypixel.io
# MEMOIR_DEV_ADMIN_PASSWORD=change-me

# =============================================================================
# Storage
# =============================================================================
DATABASE_URL=postgres://postgres:postgres@localhost:54321/memoir_service
QDRANT_URL=localhost:6334

# Knowledge graph (optional). Points at a FalkorDB / Redis-protocol endpoint.
# FALKOR_URL=redis://localhost:63792
# Graph name memoir writes to (co-tenant isolation). Defaults to "memoir".
# MEMOIR_GRAPH_NAME=memoir

# Auth/tenant tables, set to public in dev
# SERVICE_SCHEMA=memoir_service
# Memory tables, set to public in dev
# CORE_SCHEMA=memoir

# vim: ft=sh
