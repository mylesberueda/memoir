# =============================================================================
# Server
# =============================================================================
HOST=0.0.0.0
PORT=5153
NOTIFICATION_SERVICE_URL=http://localhost:5156
API_SERVICE_URL=http://localhost:5154
CONSUMER_NAME=worker-1
# Set this higher if tests are failing. In deployed environments, should be 1 or empty
RATE_LIMIT_MULTIPLIER=10

# =============================================================================
# SECRETS
# =============================================================================
CRYPTO_PASSPHRASE=crypto-passphrase
CRYPTO_SALT=crypto-salt

# =============================================================================
# AI (uncomment provider envars to enable system provider)
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEST_MODEL=llama3.2:1b
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_API_KEY=sk-openai-api-key
# GEMINI_API_KEY=your-gemini-api-key

ASSISTANT_MODEL=glm-4.7-flash:latest
ASSISTANT_PROVIDER=ollama

# =============================================================================
# S3-compatible object storage (RustFS)
# =============================================================================
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=documents
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin

# =============================================================================
# Qdrant (vector database)
# =============================================================================
QDRANT_URL=http://localhost:6334

# vim: ft=sh
