# ==============================================================================
# Server
# ==============================================================================
LOG_LEVEL=debug

# ==============================================================================
# API
# ==============================================================================
# OpenAPI Client Runtime Configuration
# Look at openapi-node/.env.example and README.md for more info
NEXT_PUBLIC_API_BASE_URL=http://localhost:5151

# ==============================================================================
# Session
# ==============================================================================
# Generate with: openssl rand -base64 32
SESSION_SECRET=dev-session-secret-change-in-production-min-32-chars

# ==============================================================================
# Playwright
# ==============================================================================
PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS=1

# ==============================================================================
# gRPC Service URLs (server-side only, NOT NEXT_PUBLIC)
# ==============================================================================
RIG_SERVICE_URL=http://localhost:5153
API_SERVICE_URL=http://localhost:5154
CHAT_SERVICE_URL=http://localhost:5155
NOTIFICATION_SERVICE_URL=http://localhost:5156

# =============================================================================
# Test
# =============================================================================
OLLAMA_TEST_MODEL=llama3.2:1b

# vim: ft=sh
