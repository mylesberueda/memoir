# ==============================================================================
# Server
# ==============================================================================
LOG_LEVEL=debug

# ==============================================================================
# Session
# ==============================================================================
# Signs the HttpOnly session cookie that holds the user's gRPC bearer JWT.
# Generate with: openssl rand -base64 32
# Rotation: prepend new secret as a comma-separated value, e.g. "new,old".
SESSION_SECRET=dev-session-secret-change-in-production-min-32-chars

# ==============================================================================
# Storage
# ==============================================================================
REDIS_URL=redis://localhost:63791

# ==============================================================================
# memoir-service
# ==============================================================================
# gRPC endpoint for memoir-service. Server-side only (NOT NEXT_PUBLIC) —
# memoir-ui's Next.js server forwards browser requests with the user's JWT
# attached as `authorization: Bearer <jwt>`.
# Required at boot: if unset, the gRPC client throws at module load and the
# whole app fails to start.
SERVICE_URL=http://localhost:5500
# Feature-gating: powers the playground chat only. If unset, the playground
# route returns 503 but the rest of the app runs.
HTTP_URL=http://localhost:5154

# The UI exposes a health check at /api/health (point k8s probes here).

# ==============================================================================
# Tests
# ==============================================================================
# Credentials of a pre-created user that integration tests log in as.
# Create out-of-band via `memoir auth create` or DEV_MODE bootstrap.
# Username must be email-shaped — the login form validates email format.
TEST_USERNAME=admin@polypixel.io
TEST_PASSWORD=change-me

# Playwright
PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS=1

# vim: ft=sh
